# Environment Variables — Cloud Deployment
# Copy this to backend/.env and fill in your values

# ── Groq API (Free) ──────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── PostgreSQL (Railway auto-fills this) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/dbname

# ── Whisper ASR (Railway Docker service) ─────────────────────────────────────
WHISPER_URL=http://whisper:9000
